// UpNext data model — see docs/07-data-model.md

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MembershipRole {
  owner
  admin
  dispatcher
  worker
  viewer
}

enum MembershipStatus {
  active
  invited
  disabled
}

enum OrganizationStatus {
  active
  suspended
}

enum ServiceAreaEnforcementMode {
  off
  zip_list
  radius
}

/// Mirrors Supabase auth.users.id — created on first sign-up.
model User {
  id          String       @id
  email       String       @unique
  name        String?
  avatarUrl   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
  ownedOrgs   Organization[] @relation("OrganizationOwner")
}

model Organization {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  ownerId           String
  timezone          String             @default("America/New_York")
  currency          String             @default("USD")
  status            OrganizationStatus @default(active)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  owner             User               @relation("OrganizationOwner", fields: [ownerId], references: [id])
  memberships       Membership[]
  businessProfile   BusinessProfile?
  services          Service[]
  availabilityRules AvailabilityRule[]
  blackoutDates     BlackoutDate[]
  customers         Customer[]
  bookingRequests   BookingRequest[]
  jobs              Job[]
  jobSeries         JobSeries[]
  paymentRecords    PaymentRecord[]
  stripeWebhookEvents StripeWebhookEvent[]
  notificationLogs  NotificationLog[]
  checklistTemplates ChecklistTemplate[]
  teamInvites       TeamInvite[]
  customerPortalTokens CustomerPortalToken[]
  apiKeys           ApiKey[]
  webhookEndpoints  WebhookEndpoint[]
  bookingFormFields BookingFormField[]
  locations         Location[]

  /// Stripe Connect account for customer payments (not UpNext SaaS billing).
  stripeConnectAccountId   String?
  stripeConnectChargesEnabled Boolean @default(false)

  @@index([slug])
}

model Membership {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole
  status         MembershipStatus @default(active)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobAssignments JobAssignment[]
  completedChecklistItems JobChecklistItem[] @relation("ChecklistCompletedBy")
  uploadedJobPhotos     JobPhoto[]         @relation("JobPhotoUploadedBy")
  sentTeamInvites       TeamInvite[]       @relation("TeamInviteSentBy")
  availabilityRules     MembershipAvailabilityRule[]

  @@unique([organizationId, userId])
  @@index([userId])
}

model BusinessProfile {
  id             String       @id @default(cuid())
  organizationId String       @unique
  displayName    String
  publicSlug     String       @unique
  businessType   String?
  teamSize       String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  region         String?
  postalCode     String?
  country        String       @default("US")
  logoUrl        String?
  phone          String?
  email          String?
  websiteUrl     String?
  serviceArea    String?
  serviceAreaEnforcementMode ServiceAreaEnforcementMode @default(off)
  serviceAreaRadiusMiles     Int?
  serviceAreaZipCodesJson      Json?
  addressLatitude              Float?
  addressLongitude             Float?
  description    String?
  onboardingCompletedAt DateTime?
  bookingEnabled        Boolean      @default(true)
  minNoticeHours              Int          @default(24)
  maxBookingDaysAhead         Int          @default(60)
  slotIntervalMinutes         Int          @default(30)
  bufferMinutesBetweenJobs    Int          @default(0)
  providerCarryOverMinutes    Int          @default(0)
  notifyOwnerNewBooking              Boolean @default(true)
  notifyCustomerBookingConfirmation  Boolean @default(true)
  notifyCustomerReminder24h          Boolean @default(true)
  notifyCustomerReminder2h           Boolean @default(false)
  notifyCustomerJobCompleted         Boolean @default(true)
  notifyCustomerPaymentRequest       Boolean @default(true)
  smsEnabled                         Boolean @default(false)
  smsFromNumber                      String?
  notifyCustomerSmsReminder24h       Boolean @default(false)
  notifyCustomerSmsOnTheWay          Boolean @default(false)
  notifyCustomerSmsRunningLate       Boolean @default(false)
  notifyWorkerSmsJobAssigned         Boolean @default(false)
  customerPortalEnabled              Boolean @default(true)
  portalPasswordLoginEnabled         Boolean @default(false)
  portalFaqJson                      Json?
  payAtBookingEnabled                Boolean @default(false)
  requirePaymentAtBooking            Boolean @default(false)
  customBookingHost                  String?  @unique
  customBookingVerifiedAt            DateTime?
  createdAt             DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([publicSlug])
}

model Location {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  addressLine1   String?
  addressLine2   String?
  city           String?
  region         String?
  postalCode     String?
  country        String   @default("US")
  phone          String?
  timezone       String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookingRequests BookingRequest[]
  jobs           Job[]

  @@index([organizationId])
  @@index([organizationId, isActive])
}

model Service {
  id              String       @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  durationMinutes Int
  basePriceCents  Int
  currency        String       @default("USD")
  isActive        Boolean      @default(true)
  isPublic        Boolean      @default(true)
  isAddon         Boolean      @default(false)
  iconKey         String?
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookingRequests BookingRequest[]
  bookingAddons   BookingRequestAddon[]
  jobs            Job[]
  jobSeries       JobSeries[]
  checklistTemplates ChecklistTemplate[]
  pricingParameters   ServicePricingParameter[]
  frequencyDiscounts  ServiceFrequencyDiscount[]

  @@index([organizationId])
  @@index([organizationId, isActive, isPublic])
}

/// dayOfWeek: 0 = Sunday … 6 = Saturday (JS Date.getDay())
model AvailabilityRule {
  id             String       @id @default(cuid())
  organizationId String
  dayOfWeek      Int
  startTime      String
  endTime        String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, dayOfWeek])
  @@index([organizationId])
}

/// Per-worker weekly hours (intersected with org AvailabilityRule for manual booking / assigned jobs).
model MembershipAvailabilityRule {
  id           String     @id @default(cuid())
  membershipId String
  dayOfWeek    Int
  startTime    String
  endTime      String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, dayOfWeek])
  @@index([membershipId])
}

model BlackoutDate {
  id             String       @id @default(cuid())
  organizationId String
  startsAt       DateTime
  endsAt         DateTime
  reason         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, startsAt])
}

enum BookingRequestStatus {
  pending
  accepted
  declined
  cancelled
  expired
}

enum BookingFrequency {
  one_time
  weekly
  biweekly
  monthly
}

model Customer {
  id             String            @id @default(cuid())
  organizationId String
  firstName      String
  lastName       String
  email          String
  phone          String?
  notes          String?
  tags           String[]          @default([])
  portalLastLoginAt DateTime?
  portalUserId      String?  @unique
  stripeCustomerId  String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  addresses      CustomerAddress[]
  bookingRequests BookingRequest[]
  jobs           Job[]
  jobSeries      JobSeries[]
  paymentRecords PaymentRecord[]
  portalTokens   CustomerPortalToken[]

  @@index([organizationId])
  @@index([organizationId, email])
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  line1      String
  line2      String?
  city       String
  region     String
  postalCode String
  country    String   @default("US")
  notes      String?
  isDefault  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobs       Job[]

  @@index([customerId])
}

model BookingRequest {
  id               String               @id @default(cuid())
  organizationId   String
  locationId       String?
  customerId       String
  serviceId        String
  requestedStartAt DateTime
  requestedEndAt   DateTime
  status           BookingRequestStatus @default(pending)
  frequency        BookingFrequency     @default(one_time)
  customerNotes    String?
  customFieldsJson Json?
  internalNotes    String?
  source           String               @default("public_booking")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location         Location?            @relation(fields: [locationId], references: [id], onDelete: SetNull)
  customer         Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service          Service              @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  job              Job?
  addons           BookingRequestAddon[]
  parameters       BookingRequestParameter[]
  paymentRecord    PaymentRecord?

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, requestedStartAt])
  @@index([organizationId, locationId])
}

enum BookingFormFieldType {
  text
  textarea
  select
  checkbox
}

model BookingFormField {
  id             String               @id @default(cuid())
  organizationId String
  key            String
  label          String
  fieldType      BookingFormFieldType @default(text)
  optionsJson    Json?
  required       Boolean              @default(false)
  sortOrder      Int                  @default(0)
  active         Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId, active, sortOrder])
}

enum JobStatus {
  scheduled
  confirmed
  in_progress
  completed
  cancelled
  no_show
}

model Job {
  id                String     @id @default(cuid())
  organizationId    String
  locationId        String?
  bookingRequestId  String?    @unique
  customerId        String
  customerAddressId String?
  serviceId         String
  title             String
  scheduledStartAt  DateTime
  scheduledEndAt    DateTime
  status            JobStatus  @default(scheduled)
  priceCents        Int
  currency          String     @default("USD")
  customerNotes     String?
  internalNotes     String?
  completionNotes   String?
  checkedInAt       DateTime?
  completedAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location          Location?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  bookingRequest    BookingRequest? @relation(fields: [bookingRequestId], references: [id], onDelete: SetNull)
  customer          Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerAddress   CustomerAddress? @relation(fields: [customerAddressId], references: [id], onDelete: SetNull)
  service           Service         @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  assignments       JobAssignment[]
  paymentRecord     PaymentRecord?
  checklistItems    JobChecklistItem[]
  photos            JobPhoto[]
  jobSeriesId       String?
  jobSeries         JobSeries? @relation("SeriesJobs", fields: [jobSeriesId], references: [id], onDelete: SetNull)
  anchorForSeries   JobSeries? @relation("SeriesAnchor")

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, scheduledStartAt])
  @@index([organizationId, locationId])
}

model JobAssignment {
  id           String     @id @default(cuid())
  jobId        String
  membershipId String
  role         String     @default("primary")
  assignedAt   DateTime   @default(now())
  job          Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([jobId, membershipId])
  @@index([membershipId])
  @@index([jobId])
}

model BookingRequestAddon {
  id               String         @id @default(cuid())
  bookingRequestId String
  serviceId        String
  name             String
  priceCents       Int
  durationMinutes  Int
  createdAt        DateTime       @default(now())
  bookingRequest   BookingRequest @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  service          Service        @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([bookingRequestId])
}

enum PricingParameterType {
  bedrooms
  bathrooms
  half_bathrooms
  square_feet
}

model ServiceFrequencyDiscount {
  id             String           @id @default(cuid())
  serviceId      String
  frequency      BookingFrequency
  percentOff     Int              @default(0)
  amountOffCents Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  service        Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, frequency])
  @@index([serviceId])
}

model ServicePricingParameter {
  id             String               @id @default(cuid())
  serviceId      String
  parameterType  PricingParameterType
  unitPriceCents Int
  includedUnits  Int                  @default(0)
  maxUnits       Int                  @default(10)
  sortOrder      Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  service        Service              @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, parameterType])
  @@index([serviceId])
}

model BookingRequestParameter {
  id               String               @id @default(cuid())
  bookingRequestId String
  parameterType    PricingParameterType
  units            Int
  createdAt        DateTime             @default(now())
  bookingRequest   BookingRequest       @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)

  @@unique([bookingRequestId, parameterType])
  @@index([bookingRequestId])
}

enum PaymentStatus {
  not_requested
  pending
  paid
  overdue
  failed
  refunded
}

enum PaymentProvider {
  manual
  stripe
}

model PaymentRecord {
  id                      String          @id @default(cuid())
  organizationId          String
  jobId                   String?         @unique
  bookingRequestId        String?         @unique
  customerId              String
  amountCents             Int
  currency                String          @default("USD")
  status                  PaymentStatus   @default(not_requested)
  provider                PaymentProvider @default(manual)
  stripePaymentIntentId   String?
  stripeCheckoutSessionId String?         @unique
  paymentUrl              String?
  paidAt                  DateTime?
  dueAt                   DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  organization            Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job                     Job?            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  bookingRequest          BookingRequest? @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  customer                Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([customerId])
}

/// Idempotent Stripe webhook processing (platform + Connect events).
model StripeWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  organizationId String?

  @@index([organizationId])
}

enum NotificationRecipientType {
  customer
  owner
  worker
}

enum NotificationChannel {
  email
  sms
}

enum NotificationStatus {
  sent
  failed
  skipped
}

enum NotificationTemplate {
  booking_confirmation
  new_booking_request
  booking_accepted
  booking_declined
  booking_rescheduled
  booking_reminder_24h
  booking_reminder_2h
  crew_job_assigned
  job_completed
  job_rescheduled
  job_on_the_way
  job_running_late
  payment_request
  team_invite
  customer_portal_link
  booking_cancelled_by_customer
  recurring_job_scheduled
}

model NotificationLog {
  id             String                    @id @default(cuid())
  organizationId String
  recipientType  NotificationRecipientType
  recipientEmail String
  channel        NotificationChannel       @default(email)
  template       NotificationTemplate
  status         NotificationStatus
  relatedType    String
  relatedId      String
  resendEmailId  String?
  error          String?
  sentAt         DateTime                  @default(now())
  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, template, relatedId])
  @@index([relatedType, relatedId])
}

model ChecklistTemplate {
  id             String       @id @default(cuid())
  organizationId String
  serviceId      String
  label          String
  sortOrder      Int          @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([serviceId])
  @@index([organizationId, serviceId])
}

model JobChecklistItem {
  id                      String      @id @default(cuid())
  jobId                   String
  label                   String
  isCompleted             Boolean     @default(false)
  completedByMembershipId String?
  completedAt             DateTime?
  sortOrder               Int         @default(0)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  job                     Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  completedBy             Membership? @relation("ChecklistCompletedBy", fields: [completedByMembershipId], references: [id], onDelete: SetNull)

  @@index([jobId])
}

enum JobPhotoType {
  before
  after
  proof
  issue
  other
}

model JobPhoto {
  id                     String       @id @default(cuid())
  jobId                  String
  uploadedByMembershipId String
  storagePath            String
  mimeType               String
  type                   JobPhotoType @default(proof)
  caption                String?
  createdAt              DateTime     @default(now())
  job                    Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  uploadedBy             Membership   @relation("JobPhotoUploadedBy", fields: [uploadedByMembershipId], references: [id], onDelete: Restrict)

  @@index([jobId])
}

model TeamInvite {
  id             String         @id @default(cuid())
  organizationId String
  email          String
  role           MembershipRole @default(worker)
  token          String         @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime       @default(now())
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy      Membership     @relation("TeamInviteSentBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([organizationId, email])
}

/// Magic-link tokens for customer portal sign-in (15 min TTL).
enum JobSeriesStatus {
  active
  paused
  cancelled
}

/// Recurring schedule spawned from an accepted booking with frequency != one_time.
model JobSeries {
  id                 String            @id @default(cuid())
  organizationId     String
  customerId         String
  serviceId          String
  customerAddressId  String?
  frequency          BookingFrequency
  anchorJobId        String?           @unique
  preferredTimeHm    String
  durationMinutes    Int
  priceCents         Int
  currency           String            @default("USD")
  nextOccurrenceAt   DateTime
  assignMembershipId String?
  status             JobSeriesStatus   @default(active)
  customerNotes      String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer           Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service            Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  anchorJob          Job?              @relation("SeriesAnchor", fields: [anchorJobId], references: [id], onDelete: SetNull)
  jobs               Job[]             @relation("SeriesJobs")

  @@index([organizationId, status, nextOccurrenceAt])
}

model CustomerPortalToken {
  id             String       @id @default(cuid())
  organizationId String
  customerId     String
  token          String       @unique
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId, customerId])
  @@index([expiresAt])
}

enum WebhookEventType {
  booking_created
  booking_accepted
  booking_canceled
  job_completed
  customer_created
  payment_paid
}

enum WebhookDeliveryStatus {
  pending
  delivered
  failed
}

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  keyPrefix      String
  keyHash        String       @unique
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([keyHash])
}

model WebhookEndpoint {
  id             String             @id @default(cuid())
  organizationId String
  url            String
  secret         String
  events         WebhookEventType[]
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries     WebhookDelivery[]

  @@index([organizationId])
}

model WebhookDelivery {
  id                String                @id @default(cuid())
  webhookEndpointId String
  event             WebhookEventType
  payload           Json
  status            WebhookDeliveryStatus @default(pending)
  attemptCount      Int                   @default(0)
  lastError         String?
  responseStatus    Int?
  createdAt         DateTime              @default(now())
  deliveredAt       DateTime?
  webhookEndpoint   WebhookEndpoint       @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)

  @@index([webhookEndpointId, createdAt])
  @@index([status, createdAt])
}
