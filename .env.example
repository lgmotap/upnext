# ── Public (safe for the browser) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://flmumvxvyhfckvmnwzin.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Server-only (never commit real values) ───────────────────────────────────
# Supabase → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Supabase → Project Settings → Database → Connection string
# DATABASE_URL  = Transaction pooler (port 6543, ?pgbouncer=true)
# DIRECT_URL    = Direct connection (port 5432) — used by Prisma migrations
DATABASE_URL=
DIRECT_URL=

# Resend → API Keys (UpNext account — see upnext-resend MCP)
RESEND_API_KEY=
# Dev only (no verified domain): test sender + inbox redirect — see docs/13-notifications.md
EMAIL_FROM=UpNext <onboarding@resend.dev>
RESEND_SANDBOX_TO=your-resend-account-email@example.com
# BEFORE PRODUCTION: verify a domain in Resend, set EMAIL_FROM=UpNext <notifications@yourdomain.com>, unset RESEND_SANDBOX_TO

# Stripe (optional — wire up when payments sprint starts)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Protects /api/cron/* — generate: openssl rand -hex 32
CRON_SECRET=

# Observability (optional locally — required for production launch checklist)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
